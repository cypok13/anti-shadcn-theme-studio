{
  "name": "theme-studio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3005",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:components": "playwright test tests/component-qa.spec.ts",
    "test:component": "playwright test tests/component-qa.spec.ts --grep",
    "lint:ui": "eslint \"src/components/ui/**/*.tsx\" --max-warnings 0",
    "docs:tokens": "npx tsx scripts/generate-token-index.ts",
    "docs:components": "npx tsx scripts/generate-component-index.ts",
    "docs:sync": "npx tsx scripts/docs-sync.ts",
    "docs:validate": "npx tsx scripts/validate-docs.ts"
  },
  "dependencies": {
    "@floating-ui/react-dom": "^2.1.8",
    "@types/culori": "^4.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "culori": "^4.0.2",
    "geist": "^1.7.0",
    "lucide-react": "^0.577.0",
    "next": "^15",
    "nuqs": "^2",
    "react": "^19",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19",
    "recharts": "^3.8.1",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "eslint-plugin-tailwindcss": "^3.18.3",
    "tailwindcss": "^4",
    "tsx": "^4.19.0",
    "typescript": "^5",
    "vitest": "^2"
  }
}
